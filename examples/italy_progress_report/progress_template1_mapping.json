      "config": {
        "state_styles": {
          "状态正常": {
            "fill": "E7F6EF",
            "line": "1EAA73"
          },
          "需要关注": {
            "fill": "FFF5D6",
            "line": "D99A00"
          },
          "存在风险": {
            "fill": "FDE2E2",
            "line": "D64545"
          }
        }
      },
      "data_source": {
        "name": "dashboard",
        "index": "$.progress_badge"
      }
    },
    {
      "location": "shape.technical_status_badge",
      "semantic_description": "技术状态徽标",
