{
  "template_id": "italy-progress-template1-v1",
  "component_list": [
    {
      "location": "text.cover_title",
      "semantic_description": "封面报告标题",
      "type": "Text",
      "config": {
        "preserve_style": true
      },
      "data_source": {
        "name": "project",
        "template": "{{ project_name }}进度报告"
      }
    },
    {
      "location": "text.cover_period",
      "semantic_description": "封面报告周期",
      "type": "Text",
      "config": {
        "preserve_style": true
      },
